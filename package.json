{
  "name": "ib-myp-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "IB-MYP Report System — Production Monorepo",
  "scripts": {
    "install:client": "cd client && npm install",
    "install:server": "cd server && npm install",
    "postinstall": "npm run install:client && npm run install:server",
    "build": "cd client && npm run build",
        "start": "node app.js",
    "dev": "concurrently -n server,client -c blue,green \"cd server && npm run dev\" \"cd client && npm run dev\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "lint": "cd client && npm run lint",
    "format": "echo \"No formatter configured\"",
    "prisma:generate": "cd server && npx prisma generate",
    "prisma:migrate": "cd server && npx prisma migrate deploy",
    "seed": "cd server && npm run seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}

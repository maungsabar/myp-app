# ═══════════════════════════════════════════════════════════
# IB-MYP Server — Environment Variables (Production Template)
# ═══════════════════════════════════════════════════════════
# Copy file ini ke .env dan isi dengan nilai yang sesuai.
# JANGAN commit file .env ke repository!

# ─── Server ────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── Database (MySQL) ─────────────────────────────────────
# Format: mysql://USERNAME:PASSWORD@HOST:PORT/DATABASE
# Gunakan password yang kuat (min 16 karakter, kombinasi huruf/angka/simbol)
# Contoh: mysql://ibmyp_user:X9#kL2$mP7@vQ4nR@db.example.com:3306/ib_myp_production
DATABASE_URL="mysql://ibmyp_user:GANTI_DENGAN_PASSWORD_KUAT@localhost:3306/ib_myp_production"

# ─── CORS (Cross-Origin Resource Sharing) ─────────────────
# Domain frontend yang diizinkan mengakses API.
# Pisahkan dengan koma jika ada lebih dari satu domain.
# Contoh: https://rapor.sekolah.sch.id,https://admin.sekolah.sch.id
CORS_ORIGIN="https://rapor.sekolah.sch.id"

# ─── Security ─────────────────────────────────────────────
# Secret key untuk JWT (akan digunakan saat fitur auth diaktifkan)
# Generate dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="GANTI_DENGAN_RANDOM_STRING_64_KARAKTER"

# ─── Rate Limiting ────────────────────────────────────────
# Batasi jumlah request per IP untuk mencegah abuse
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ──────────────────────────────────────────────
# Level: error, warn, info, debug
LOG_LEVEL=info
